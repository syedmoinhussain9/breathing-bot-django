#: core/presets.py:5
msgid "1-4-2 Lung Conditioning Pattern"
msgstr "Phương pháp rèn luyện phổi 1-4-2"

#: core/presets.py:13
msgid "A classic respiratory conditioning sequence designed to maximize blood oxygenation and expand vital lung capacity over time."
msgstr "Một chuỗi bài tập điều hòa hô hấp cổ điển được thiết kế để tối đa hóa lượng oxy trong máu và tăng dung tích phổi theo thời gian."

#: core/presets.py:16
msgid "Box Breathing (Navy SEAL Tactical Clarity)"
msgstr "Box Breathing (Kỹ thuật tăng cường sự tập trung của đặc nhiệm Navy SEAL)"

#: core/presets.py:24
msgid "The gold standard for high-stress grounding. Equal duration phases clear cortisol, settle racing hearts, and restore sharp mental clarity."
msgstr "Tiêu chuẩn vàng giúp trấn tĩnh khi căng thẳng cao độ. Các giai đoạn có thời gian bằng nhau giúp loại bỏ cortisol, ổn định nhịp tim và phục hồi sự minh mẫn."

#: core/presets.py:27
msgid "4-7-8 Relaxation (Nervous System Tranquilizer)"
msgstr "Kỹ thuật thư giãn 4-7-8 (Giúp trấn an hệ thần kinh)"

#: core/presets.py:35
msgid "Acts as a natural chemical brake for your sympathetic nervous system. Highly recommended for severe anxiety and floating into deep sleep."
msgstr "Hoạt động như một 'phanh hóa học' tự nhiên cho hệ thần kinh giao cảm. Rất khuyến khích cho tình trạng lo âu nghiêm trọng và đi vào giấc ngủ sâu."

#: core/presets.py:38
msgid "Coherent / Resonant Breathing (Asthma & Panic Relief)"
msgstr "Thở cộng hưởng (Hỗ trợ giảm hen suyễn & hoảng loạn)"

#: core/presets.py:46
msgid "Balances the vagus nerve and optimizes heart rate variability (HRV). Zero hold times make this perfectly safe for active asthma management."
msgstr "Cân bằng dây thần kinh phế vị và tối ưu hóa sự biến thiên nhịp tim (HRV). Không nín thở giúp phương pháp này hoàn toàn an toàn cho người bị hen suyễn."

#: core/presets.py:49
msgid "Tactical Breathing (Sustained Equilibrium)"
msgstr "Thở chiến thuật (Duy trì trạng thái cân bằng)"

#: core/presets.py:57
msgid "A specialized, low-overhead holding variant used by responders to reduce somatic anxiety without inducing lightheadedness."
msgstr "Một biến thể nín thở chuyên biệt được các nhân viên phản ứng nhanh sử dụng để giảm lo âu thể chất mà không gây choáng váng."

#: core/presets.py:60
msgid "Pursed-Lip Splinting (COPD & Air-Trapping Relief)"
msgstr "Thở chúm môi (Hỗ trợ COPD & giảm khí tồn dư)"

#: core/presets.py:68
msgid "Creates passive mechanical backpressure to keep bronchial pathways open. Crucial for individuals with emphysema or structural shortness of breath."
msgstr "Tạo áp lực ngược cơ học thụ động để giữ cho đường phế quản luôn mở. Rất quan trọng đối với người bị khí phế thũng hoặc khó thở do cấu trúc phổi."

#: core/presets.py:71
msgid "Physiological Sigh (Acute Hyperventilation Intercept)"
msgstr "Tiếng thở dài sinh lý (Ngắt quãng tình trạng tăng thông khí cấp tính)"

#: core/presets.py:79
msgid "Simulates the biological double-inhale reflex to instantly re-inflate collapsed alveoli and maximize immediate carbon dioxide unloading."
msgstr "Mô phỏng phản xạ hít vào kép sinh học để làm phồng lại các phế nang bị xẹp và tối đa hóa việc giải phóng khí carbon dioxide ngay lập tức."

#: core/presets.py:82
msgid "Extended Cardiac Exhale (Hypertension / Vagal Tone)"
msgstr "Thở ra kéo dài (Hỗ trợ cao huyết áp / Tăng cường dây thần kinh phế vị)"

#: core/presets.py:90
msgid "Exhale window is mathematically doubled relative to inhale. Maximizes acetylcholinergic outflow to safely downregulate heart rate and blood pressure."
msgstr "Thời gian thở ra được kéo dài gấp đôi so với hít vào. Tối đa hóa dòng acetylcholinergic để điều chỉnh giảm nhịp tim và huyết áp một cách an toàn."

