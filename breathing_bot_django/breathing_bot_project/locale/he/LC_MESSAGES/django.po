#: core/presets.py:5
msgid "1-4-2 Lung Conditioning Pattern"
msgstr "תבנית אימון ריאות 1-4-2"

#: core/presets.py:13
msgid "A classic respiratory conditioning sequence designed to maximize blood oxygenation and expand vital lung capacity over time."
msgstr "רצף אימון נשימתי קלאסי שנועד למקסם את חימצון הדם ולהרחיב את קיבולת הריאות לאורך זמן."

#: core/presets.py:16
msgid "Box Breathing (Navy SEAL Tactical Clarity)"
msgstr "נשימת קופסה (מיקוד טקטי של אריות הים)"

#: core/presets.py:24
msgid "The gold standard for high-stress grounding. Equal duration phases clear cortisol, settle racing hearts, and restore sharp mental clarity."
msgstr "תקן הזהב לקרקוע במצבי לחץ גבוה. שלבים בעלי משך זמן שווה מנקים קורטיזול, מרגיעים דפיקות לב ומשיבים בהירות מנטלית חדה."

#: core/presets.py:27
msgid "4-7-8 Relaxation (Nervous System Tranquilizer)"
msgstr "הרפיית 4-7-8 (להרגעת מערכת העצבים)"

#: core/presets.py:35
msgid "Acts as a natural chemical brake for your sympathetic nervous system. Highly recommended for severe anxiety and floating into deep sleep."
msgstr "משמש כבלם כימי טבעי למערכת העצבים הסימפתטית. מומלץ מאוד לחרדה חריפה וכניסה לשינה עמוקה."

#: core/presets.py:38
msgid "Coherent / Resonant Breathing (Asthma & Panic Relief)"
msgstr "נשימה קוהרנטית / תהודתית (הקלה באסתמה ופאניקה)"

#: core/presets.py:46
msgid "Balances the vagus nerve and optimizes heart rate variability (HRV). Zero hold times make this perfectly safe for active asthma management."
msgstr "מאזנת את העצב התועה (ואגוס) וממטבת את שונות קצב הלב (HRV). היעדר זמני עצירה הופך אותה לבטוחה לחלוטין לניהול אסתמה פעיל."

#: core/presets.py:49
msgid "Tactical Breathing (Sustained Equilibrium)"
msgstr "נשימה טקטית (איזון מתמשך)"

#: core/presets.py:57
msgid "A specialized, low-overhead holding variant used by responders to reduce somatic anxiety without inducing lightheadedness."
msgstr "וריאציה מיוחדת עם עצירות נשימה קצרות המשמשת כוחות חירום להפחתת חרדה גופנית ללא גרימת סחרחורת."

#: core/presets.py:60
msgid "Pursed-Lip Splinting (COPD & Air-Trapping Relief)"
msgstr "נשימת שפתיים קפוצות (הקלה ב-COPD וכליאת אוויר)"

#: core/presets.py:68
msgid "Creates passive mechanical backpressure to keep bronchial pathways open. Crucial for individuals with emphysema or structural shortness of breath."
msgstr "יוצרת לחץ נגדי מכני פסיבי לשמירה על דרכי הנשימה פתוחות. חיונית לאנשים עם אמפיזמה או קוצר נשימה מבני."

#: core/presets.py:71
msgid "Physiological Sigh (Acute Hyperventilation Intercept)"
msgstr "אנחה פיזיולוגית (למניעת היפרוונטילציה חריפה)"

#: core/presets.py:79
msgid "Simulates the biological double-inhale reflex to instantly re-inflate collapsed alveoli and maximize immediate carbon dioxide unloading."
msgstr "מדמה את רפלקס השאיפה הכפולה הביולוגי לניפוח מיידי של נאדיות הריאה ומקסום פליטת פחמן דו-חמצני."

#: core/presets.py:82
msgid "Extended Cardiac Exhale (Hypertension / Vagal Tone)"
msgstr "נשיפה קרדיאלית מורחבת (יתר לחץ דם / טונוס ואגאלי)"

#: core/presets.py:90
msgid "Exhale window is mathematically doubled relative to inhale. Maximizes acetylcholinergic outflow to safely downregulate heart rate and blood pressure."
msgstr "זמן הנשיפה כפול מתמטית ביחס לשאיפה. ממקסם את הפעילות העצבית להורדה בטוחה של דופק ולחץ דם."

